# PostgreSQL database URL (Neon, Supabase, or local Postgres)
DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# NextAuth v5 secret — generate with: openssl rand -base64 32
AUTH_SECRET=your-random-secret-here

# Google Gemini API key (FREE) — get it at: https://aistudio.google.com/apikey
# Free tier: 15 requests/min, 1 million tokens/day — no credit card required
GEMINI_API_KEY=your-gemini-api-key-here
